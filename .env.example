# ─── Telegram Bot Configuration ───────────────────────────────────────────────
BOT_TOKEN=your_bot_token_from_botfather
BOT_USERNAME=YourEscrowBot
ADMIN_USER_IDS=123456789,987654321

# ─── MongoDB Configuration ────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=escrow_bot

# ─── Blockchain RPC Endpoints ─────────────────────────────────────────────────
BSC_RPC_URL=https://bsc-dataseed.binance.org/
TRON_RPC_URL=https://api.trongrid.io
TRON_API_KEY=your_trongrid_api_key

# ─── USDT Contract Addresses ─────────────────────────────────────────────────
BSC_USDT_CONTRACT=0x55d398326f99059fF775485246999027B3197955
TRON_USDT_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t

# ─── Escrow Wallet (Hot Wallet) ──────────────────────────────────────────────
# BSC/BEP20 Wallet
ESCROW_BSC_PRIVATE_KEY=your_bsc_private_key
ESCROW_BSC_ADDRESS=0xYourBSCWalletAddress

# TRON/TRC20 Wallet
ESCROW_TRON_PRIVATE_KEY=your_tron_private_key
ESCROW_TRON_ADDRESS=TYourTronWalletAddress

# ─── Trade Settings ───────────────────────────────────────────────────────────
DEPOSIT_ADDRESS_TIMEOUT_MINUTES=20
PAYMENT_CHECK_INTERVAL_SECONDS=60

# ─── Bot Fee (percentage taken from each trade) ───────────────────────────────
BOT_FEE_PERCENT=1.0

# ─── Group Photo Path ─────────────────────────────────────────────────────────
GROUP_PHOTO_PATH=assets/escrow_group_photo.jpg
