# ============================================================
#  Telegram Escrow Bot - Environment Configuration
#  Copy this file to ".env" and fill in your real values.
# ============================================================

# --- Telegram Bot (from @BotFather) ---
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# --- Telegram API credentials (from https://my.telegram.org) ---
# Required by Telethon to create escrow groups via a USER account.
# Bots cannot create groups through the Bot API, so a user session is used.
API_ID=1234567
API_HASH=0123456789abcdef0123456789abcdef
# Phone number of the user account used to create groups (international format)
USERBOT_PHONE=+10000000000
# Session string for the userbot (generate once with scripts/generate_session.py)
USERBOT_SESSION=

# Bot username (without @) so the userbot can add the bot to created groups
BOT_USERNAME=MyEscrowBot

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=escrow_bot

# --- Escrow settings ---
# Fee charged by the escrow service, in percent
ESCROW_FEE_PERCENT=2.0
# Minutes before a generated deposit address expires
DEPOSIT_ADDRESS_TTL_MINUTES=20
# How often (seconds) to poll the blockchain for incoming payments
PAYMENT_POLL_INTERVAL_SECONDS=60
# Path to an image used as the group profile photo after a trade starts
GROUP_PHOTO_PATH=assets/escrow_group.jpg

# --- Blockchain RPC endpoints ---
# BSC (BEP20) JSON-RPC node
BSC_RPC_URL=https://bsc-dataseed.binance.org
# USDT BEP20 contract address on BSC
USDT_BEP20_CONTRACT=0x55d398326f99059fF775485246999027B3197955

# TRON (TRC20) full node
TRON_NETWORK=mainnet
TRON_API_KEY=
# USDT TRC20 contract address on TRON
USDT_TRC20_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t

# Block explorer API for BTC / LTC balance checks (BlockCypher token optional)
BLOCKCYPHER_TOKEN=
